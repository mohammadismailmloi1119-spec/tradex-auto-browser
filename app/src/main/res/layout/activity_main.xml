<?xml version="1.0" encoding="utf-8"?>
<!-- Main kiosk browser layout — full-screen WebView with overlays -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- WebView container -->
    <FrameLayout
        android:id="@+id/webview_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Progress bar (top edge, cyan accent) -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:max="100"
        android:progressTint="@color/progress_bar"
        android:visibility="gone"
        android:indeterminate="false" />

    <!-- Offline overlay — dark theme -->
    <LinearLayout
        android:id="@+id/offline_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/offline_background"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Offline icon -->
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_signal_wifi_off"
            android:contentDescription="@string/offline_title"
            android:alpha="0.4" />

        <TextView
            android:id="@+id/offline_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/offline_message"
            android:textColor="@color/offline_text"
            android:textSize="16sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/offline_retry_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/btn_retry_background"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:paddingHorizontal="32dp"
            android:paddingVertical="12dp"
            android:text="@string/retry"
            android:textColor="@color/primary_dark"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</FrameLayout>
